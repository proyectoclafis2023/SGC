# SGC - Backend Environment Configuration
PORT=3001
NODE_ENV=development

# Database Connection
# Use SQLite for local development
DATABASE_URL="file:./dev.db"

# Security
# Will be automatically generated by setup.sh
JWT_SECRET=your_super_secret_jwt_key_here

# Initial Setup & Seeding
ADMIN_EMAIL=gdcuentas@sgc.cl
ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=sgc123

# DOCTOR ALERTS (v3.5.0)
DOCTOR_ALERT_EMAIL_ENABLED=true
DOCTOR_ALERT_WEBHOOK_URL=
DOCTOR_ALERT_THRESHOLD_WARNING=90
DOCTOR_ALERT_THRESHOLD_ERROR=70
DOCTOR_ALERT_COOLDOWN_MIN=15
